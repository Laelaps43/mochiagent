# Mochi Agent 配置文件示例
# 复制此文件为 .env 并修改值

# ============ MessageBus 配置 ============
# 队列超时时间（秒）
MOCHI_QUEUE_TIMEOUT=1.0
# 最大并发处理数
MOCHI_MAX_CONCURRENT=50

# ============ System 配置 ============
# UUID 前缀长度（16进制字符数）
MOCHI_UUID_PREFIX_LENGTH=16
# 会话默认状态
MOCHI_DEFAULT_SESSION_STATE=idle

# ============ Tool 配置 ============
# 工具执行超时时间（秒）
MOCHI_TIMEOUT=30
# 批量工具最大并发数
MOCHI_MAX_BATCH_CONCURRENCY=10
# 执行输出最大字符数
MOCHI_EXEC_MAX_OUTPUT_CHARS=20000
# Web 抓取最大字符数
MOCHI_WEB_FETCH_MAX_CHARS=20000
# Web 搜索 API Key
MOCHI_WEB_SEARCH_API_KEY=

# ============ LLM 配置 ============
# 通常通过代码配置，不建议放在 .env
# OPENAI_API_KEY=your-key-here
# OPENAI_BASE_URL=https://api.openai.com/v1
